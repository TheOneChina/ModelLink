{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ModelLink",
  "version": "2.0.0",
  "identifier": "com.modellink",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ModelLink — Winhao学AI",
        "visible": true,
        "center": true,
        "width": 880,
        "height": 640,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": {
          "width": 660,
          "height": 428
        },
        "appPosition": {
          "x": 180,
          "y": 240
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 240
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Win-Hao/ModelLink/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGNkM2NjYwNTQ2Q0M0MzkKUldRNXhHeFVZR1pzUHc5aEVVK3hISjdsVDdyd0dmMHpUTTdxUkkwd0VxQ1Rtem9rYWpwMkhJa0oK"
    }
  }
}
