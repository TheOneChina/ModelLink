# 复制本文件为 signing.local.env（同目录，已 gitignore，不会提交），填你的凭据。
# 本地打包 ModelLink 用：mac 代码签名 + 公证 + 自更新签名。
# 三组齐全 → 出「已签名+已公证+可自更新」的 .dmg；缺哪组少哪步（缺公证 = 自更新被 Gatekeeper 拦）。
# Apple 凭据可与 ClaudeCN 共用同一套（直接从 ClaudeCN/gui-tauri/scripts/signing.local.env 拷前两组）。

# ① 代码签名（Developer ID）——直接用钥匙串里的证书，不用导 .p12。
#    查准确名字：security find-identity -v -p codesigning | grep "Developer ID Application"
export APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# ② 公证 —— App Store Connect API Key（推荐）。
export APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"   # Issuer ID
export APPLE_API_KEY="XXXXXXXXXX"                                 # Key ID（10 位）
export APPLE_API_KEY_PATH="$HOME/.appstoreconnect/AuthKey_XXXXXXXXXX.p8"

#    —— 或者改用 Apple ID + App 专用密码（二选一，上面 API Key 用了就不用这个）：
# export APPLE_ID="you@example.com"
# export APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # appleid.apple.com 建的 App 专用密码
# export APPLE_TEAM_ID="TEAMID"

# ③ 更新签名（minisign）—— 可省略：build-mac.sh 默认读 ~/.modellink-updater/modellink.key
# export TAURI_SIGNING_PRIVATE_KEY="$(cat ~/.modellink-updater/modellink.key)"
# export TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""
